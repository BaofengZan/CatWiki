#!/bin/sh
set -e

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

echo "[pre-commit] running make format"
make format

PY_FILES="$(printf '%s\n' "$STAGED_FILES" | grep '^backend/.*\.py$' || true)"
if [ -n "$PY_FILES" ]; then
  echo "[pre-commit] running backend lint check (staged python files)"
  REL_PY_FILES="$(printf '%s\n' "$PY_FILES" | sed 's#^backend/##')"
  cd backend
  # shellcheck disable=SC2086
  uv run ruff check $REL_PY_FILES
  cd - >/dev/null
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^frontend/admin/.*\.(ts|tsx)$'; then
  echo "[pre-commit] running frontend type check (admin)"
  cd frontend/admin
  pnpm exec tsc --noEmit
  cd - >/dev/null
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^frontend/client/.*\.(ts|tsx)$'; then
  echo "[pre-commit] running frontend type check (client)"
  cd frontend/client
  pnpm exec tsc --noEmit
  cd - >/dev/null
fi

echo "[pre-commit] restaging formatted files"
git add -A
